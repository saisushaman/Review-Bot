# ── Slack (Events API) ─────────────────────────────────────────────
# A Slack app is required to receive events. Create one at api.slack.com/apps:
#   • Event Subscriptions → subscribe to bot event `message.channels`
#     (and `app_mention` if you prefer @-mention triggering), Request URL:
#     https://<your-host>/slack/events
#   • OAuth scopes: channels:history, reactions:read, reactions:write,
#     chat:write  (+ groups:history if the channel is private)
#   • Install to the workspace, then copy the tokens below.
SLACK_SIGNING_SECRET=            # Basic Information → Signing Secret (verifies inbound events)
SLACK_TOKEN=                     # xoxb-… bot token (or xoxp-… user token to act "as you")
SLACK_CHANNEL_ID=C01234567       # the channel the bot polls, e.g. #request-pr-review

# The Slack user the request must @-tag to be eligible (the reviewer's user id).
REQUIRE_TAG_USER_ID=U01234567

# ── GitHub ─────────────────────────────────────────────────────────
# A token with `repo` scope (reuse your PAT for now; move to a GitHub App later).
GITHUB_TOKEN=
# Optional allowlist, comma-separated "owner/repo". Empty = any repo linked in the channel.
REPO_ALLOWLIST=

# ── Claude (the actual reviewer) ───────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Behavior ───────────────────────────────────────────────────────
PORT=3000
CLAIM_DEBOUNCE_MS=5000           # wait, then re-check for :eyes: before claiming
CLAIM_EMOJI=eyes
APPROVED_EMOJI=white_check_mark
SKIP_OWN_PRS=true                # never review a PR authored by the token's own user
APPROVE_WHEN_ADDRESSED=true      # verify + approve after author replies "addressed" & threads resolve
MAX_DIFF_BYTES=200000            # cap the diff sent to the model
