{
  "name": "pr-review-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous PR review bot: Slack-triggered, Claude-powered code review that posts to GitHub. Standalone port of the pr-review-bot Claude Code skill.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@octokit/rest": "^22.0.0",
    "@slack/bolt": "^4.4.0",
    "dotenv": "^17.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
